{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://capsule.dev/schemas/manifest-1.0.schema.json",
  "title": "Capsule Manifest 1.0",
  "type": "object",
  "required": [
    "capsule_version",
    "name",
    "slug",
    "version",
    "description",
    "entry",
    "permissions",
    "network"
  ],
  "additionalProperties": false,
  "properties": {
    "capsule_version": {
      "type": "string",
      "const": "1.0"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "entry": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!/)(?!.*\\.\\.)(?!.*\\u0000).+\\.(html|htm)$"
    },
    "author": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "id": {
          "type": "string",
          "maxLength": 240
        },
        "url": {
          "type": "string",
          "format": "uri",
          "maxLength": 500
        }
      }
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capability", "scope", "reason"],
        "additionalProperties": false,
        "properties": {
          "capability": {
            "type": "string",
            "enum": [
              "storage.local",
              "filesystem.import",
              "filesystem.export",
              "clipboard.write",
              "network.fetch",
              "dialog.open"
            ]
          },
          "scope": {
            "oneOf": [
              { "type": "string", "minLength": 1, "maxLength": 240 },
              {
                "type": "array",
                "items": { "type": "string", "minLength": 1, "maxLength": 240 },
                "uniqueItems": true,
                "maxItems": 50
              }
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "required": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "maxItems": 50
    },
    "network": {
      "type": "object",
      "required": ["default", "allow"],
      "additionalProperties": false,
      "properties": {
        "default": {
          "type": "string",
          "const": "deny"
        },
        "allow": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9.-]+(:[0-9]{1,5})?$"
          },
          "uniqueItems": true,
          "maxItems": 100
        }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 120 },
          "uniqueItems": true
        },
        "optional": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 120 },
          "uniqueItems": true
        }
      }
    },
    "integrity": {
      "type": "object",
      "required": ["content_hash", "algorithm"],
      "additionalProperties": false,
      "properties": {
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        },
        "algorithm": {
          "type": "string",
          "const": "sha256"
        }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "icon": {
          "type": "string",
          "maxLength": 512
        },
        "accent_color": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "preferred_size": {
          "type": "object",
          "required": ["width", "height"],
          "additionalProperties": false,
          "properties": {
            "width": { "type": "integer", "minimum": 320, "maximum": 3840 },
            "height": { "type": "integer", "minimum": 240, "maximum": 2160 }
          }
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "url": { "type": "string", "format": "uri", "maxLength": 500 }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "format": "uri", "maxLength": 500 },
        "path": { "type": "string", "maxLength": 512 }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": { "type": "string", "maxLength": 500 },
        "data_stored": {
          "type": "array",
          "items": { "type": "string", "maxLength": 120 }
        },
        "data_shared": {
          "type": "array",
          "items": { "type": "string", "maxLength": 120 }
        }
      }
    }
  }
}

